# Kalshi API credentials — generate at kalshi.com -> Account & Security -> API Keys.
# Save the downloaded private key file and point KALSHI_PRIVATE_KEY_PATH at it.
# Leave both blank to run in read-only scan mode (no trading).
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=~/.kalshi/kalshi-key.pem
# Set to true to use Kalshi's demo environment instead of production
KALSHI_DEMO=false

BANKROLL=500
KELLY_FRACTION=0.5
MAX_BET_PCT=0.05
EDGE_THRESHOLD=0.05
MAX_SPREAD_CENTS=10
# Only consider markets expiring within this many hours (1 = upcoming hour only)
MAX_EXPIRY_HOURS=1
# XGBoost weight in the ensemble (0 = lognormal only; raise once retrained on real data)
ML_WEIGHT=0
AUTO_TRADE=false
